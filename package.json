{
  "name": "sp404-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first toolkit for preparing samples for the Roland SP-404SX and SP-404A.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @sp404-toolkit/web",
    "build": "tsc -b && npm run build --workspace @sp404-toolkit/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean",
    "lab:build": "npm run build --workspace @sp404-toolkit/reverse-engineering-lab",
    "lab:generate": "npm run lab:build && node packages/reverse-engineering-lab/dist/cli/generate.js",
    "lab:fixtures": "npm run lab:generate -- --preset initial --output-dir fixtures/source",
    "lab:inspect": "npm run lab:build && node packages/reverse-engineering-lab/dist/cli/inspect-wav.js",
    "lab:compare": "npm run lab:build && node packages/reverse-engineering-lab/dist/cli/compare-binary.js",
    "lab:validate-experiment": "npm run lab:build && node packages/reverse-engineering-lab/dist/cli/validate-experiment.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
